{
  "rules": {
    "frtv": {
      // League index — any authenticated user can read; only admin can write
      "league_index": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true"
      },

      // Site announcement — any authenticated user can read; only admin can write
      "site_announcement": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true"
      },

      // Feature flags — any authenticated user can read; only admin can write
      "feature_flags": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true"
      },

      // v2.6.25.0 / v2.6.27.8: per-league read gating. Three categories
      // of children sit under `frtv/`: the user-facing league doc at
      // frtv/league_<id>, the sibling chat path at frtv/league_<id>_chat
      // (gated by members map — see below), and the admin paths matched
      // above. The wildcard here applies to everything under frtv that
      // isn't explicitly named.
      //
      // v2.6.27.13: chat reads are now membership-gated. The previous
      // rule had a `$league_key.contains('_chat')` short-circuit that
      // made chat auth-readable to anyone signed in. Phase 1 (v2.6.27.8,
      // commit 62a8a29) deployed code that writes a `members` sibling
      // map at every chat path on every saveLeague(), plus a one-time
      // admin backfill that populates the same map for existing leagues.
      // Phase 2 (this rule) drops the short-circuit and requires the
      // same members check for chat paths as for league docs.
      //
      // PRE-DEPLOY CHECKLIST:
      //   1. v2.6.27.8 must be in production AND
      //   2. The admin must have signed in to that build at least once
      //      so the backfill effect has stamped their profile with
      //      `chatMembersBackfilledAt`. Verify via the RTDB console at
      //      `frtv_users/sQE6Z9On55c7rLpsEBz8Hg5VQCk2/chatMembersBackfilledAt`.
      //   3. Spot-check a few `frtv/league_<id>_chat/members/<uid>: true`
      //      entries to confirm the map exists.
      // If any of the above isn't true and this rule is deployed, every
      // existing league's chat reads will fail until each league's
      // saveLeague() next fires.
      //
      // Read rule:
      //   - Any path (league doc OR chat) — readable when:
      //       * (League docs only) the league is marked public
      //         (`isPublic === true`), OR
      //       * The signed-in user's UID is in the path's `members` map.
      //         For league docs this is the original v2.6.25.0 map; for
      //         chat paths this is the mirrored map at
      //         frtv/league_<id>_chat/members.
      //   - Admin can read anything (defense in depth, same UID +
      //     verified check used for the other admin paths).
      //
      // Write rule stays open to any auth user so the join flow works
      // and chat messages can be posted — message validation is handled
      // client-side via sendChatMessage.
      "$league_key": {
        ".read": "auth != null && (data.child('isPublic').val() === true || data.child('members').child(auth.uid).val() === true || (auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true))",
        ".write": "auth != null"
      }
    },

    // Global scoring rule library (v2.6.2.0) — keyed by show. Any authenticated
    // user can read so commissioners' "Add from Library" picker can merge in
    // admin-added rules; only admin can write.
    "scoringRuleLibrary": {
      ".read": "auth != null",
      ".write": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true"
    },

    // Restructured rule library (v2.6.19.0) — replaces scoringRuleLibrary.
    // Path: scoringLibrary/<showType>/<ruleId> = { label, description, points,
    // category, isElimination, isBase }. Same access pattern as the legacy
    // path: any authenticated user can read so commissioners' "Add from
    // Library" picker can pull admin-managed rules; only admin can write.
    "scoringLibrary": {
      ".read": "auth != null",
      ".write": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true"
    },

    // Show-wide episode scoring (v2.6.3.0) — admin scores events that cascade
    // to opted-in leagues. Any authenticated user can read so each league can
    // merge in the events at render time; only admin can write.
    "showScoring": {
      ".read": "auth != null",
      ".write": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true"
    },

    // Show cast (v2.6.6.0) — admin defines contestants once per (show, season)
    // and commissioners can import the cast into their league with one click.
    // Any authenticated user can read; only admin can write.
    "showCast": {
      ".read": "auth != null",
      ".write": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true"
    },

    // User profiles — users can read/write their own; admin can read/write all.
    // v2.6.3.0: added parent-level .read for admin so the admin Stats / Users
    // tabs can list all profiles via a single get() at the collection level.
    // (Previously rules only allowed per-uid reads, so loadAllUserProfiles
    // returned {} for the admin and the Stats user count showed 0.)
    "frtv_users": {
      ".read": "auth != null && auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || (auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true))",
        ".write": "auth != null && (auth.uid === $uid || (auth.uid === 'sQE6Z9On55c7rLpsEBz8Hg5VQCk2' && auth.token.email_verified === true))"
      }
    }
  }
}